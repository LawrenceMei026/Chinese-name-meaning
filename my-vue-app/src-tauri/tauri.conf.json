{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chinese Name Meaning Explorer",
  "version": "0.0.0",
  "identifier": "com.chinese-name-meaning.explorer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' tauri://* https://tauri.localhost;"
    },
    "windows": [
      {
        "title": "Chinese Name Meaning Explorer",
        "width": 1200,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "targets": ["msi", "nsis"],
    "resources": ["../public/models/*", "../public/data/*"]
  }
}
